{
  "$defs": {
    "Stage": {
      "enum": [
        "INTAKE",
        "SENSE",
        "MODEL",
        "COMPOSE",
        "DECIDE",
        "SIMULATE",
        "EXECUTE",
        "OBSERVE",
        "DEMO",
        "BUNDLE"
      ],
      "title": "Stage",
      "type": "string"
    }
  },
  "additionalProperties": false,
  "properties": {
    "alpha": {
      "exclusiveMinimum": 0.0,
      "maximum": 1.0,
      "title": "Alpha",
      "type": "number"
    },
    "consumer_stage": {
      "$ref": "#/$defs/Stage"
    },
    "created_at": {
      "format": "date-time",
      "title": "Created At",
      "type": "string"
    },
    "evidence": {
      "items": {
        "type": "string"
      },
      "title": "Evidence",
      "type": "array"
    },
    "expected_success_before": {
      "maximum": 1.0,
      "minimum": 0.0,
      "title": "Expected Success Before",
      "type": "number"
    },
    "producer_stage": {
      "$ref": "#/$defs/Stage"
    },
    "proposed_delta": {
      "title": "Proposed Delta",
      "type": "number"
    },
    "reward": {
      "maximum": 1,
      "minimum": 0,
      "title": "Reward",
      "type": "integer"
    },
    "reward_prediction_error": {
      "maximum": 1.0,
      "minimum": -1.0,
      "title": "Reward Prediction Error",
      "type": "number"
    },
    "run_id": {
      "title": "Run Id",
      "type": "string"
    },
    "schema_version": {
      "default": "1.0",
      "title": "Schema Version",
      "type": "string"
    },
    "shadow_trust_after": {
      "maximum": 1.0,
      "minimum": -1.0,
      "title": "Shadow Trust After",
      "type": "number"
    },
    "source": {
      "title": "Source",
      "type": "string"
    },
    "target": {
      "title": "Target",
      "type": "string"
    },
    "trust_before": {
      "maximum": 1.0,
      "minimum": -1.0,
      "title": "Trust Before",
      "type": "number"
    },
    "unclamped_delta": {
      "title": "Unclamped Delta",
      "type": "number"
    },
    "update_id": {
      "title": "Update Id",
      "type": "string"
    }
  },
  "required": [
    "update_id",
    "run_id",
    "producer_stage",
    "consumer_stage",
    "source",
    "target",
    "reward",
    "expected_success_before",
    "reward_prediction_error",
    "alpha",
    "unclamped_delta",
    "proposed_delta",
    "trust_before",
    "shadow_trust_after"
