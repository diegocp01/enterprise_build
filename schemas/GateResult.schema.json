        "type": "boolean"
      },
      "title": "Rule Results",
      "type": "object"
    },
    "stage": {
      "$ref": "#/$defs/Stage"
    }
  },
  "required": [
    "stage",
    "decision",
    "rule_results"
  ],
  "title": "GateResult",
  "type": "object"
