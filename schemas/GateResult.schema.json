      "title": "ReviewFinding",
      "type": "object"
    },
    "Stage": {
      "enum": [
        "INTAKE",
        "SENSE",
        "MODEL",
        "COMPOSE",
        "DECIDE",
        "SIMULATE",
        "EXECUTE",
        "OBSERVE",
        "DEMO",
        "BUNDLE"
