{
  "$defs": {
    "Stage": {
      "enum": [
        "INTAKE",
        "SENSE",
        "MODEL",
        "COMPOSE",
        "DECIDE",
        "SIMULATE",
        "EXECUTE",
        "OBSERVE",
        "DEMO",
        "BUNDLE"
      ],
      "title": "Stage",
      "type": "string"
    }
  },
  "additionalProperties": false,
  "properties": {
    "assessments": {
      "additionalProperties": {
        "type": "boolean"
      },
      "title": "Assessments",
      "type": "object"
    },
    "consumer_agents": {
      "items": {
        "type": "string"
      },
      "title": "Consumer Agents",
      "type": "array"
    },
    "consumer_stage": {
      "$ref": "#/$defs/Stage"
    },
    "created_at": {
      "format": "date-time",
      "title": "Created At",
      "type": "string"
    },
    "evidence": {
      "items": {
        "type": "string"
      },
      "title": "Evidence",
      "type": "array"
    },
    "producer_agents": {
      "items": {
        "type": "string"
      },
      "title": "Producer Agents",
      "type": "array"
    },
    "producer_stage": {
      "$ref": "#/$defs/Stage"
    },
    "revised": {
      "default": false,
      "title": "Revised",
      "type": "boolean"
    },
    "revision_requests": {
      "additionalProperties": {
        "items": {
          "type": "string"
        },
        "type": "array"
      },
      "title": "Revision Requests",
      "type": "object"
    },
    "reward": {
      "maximum": 1,
      "minimum": 0,
      "title": "Reward",
      "type": "integer"
    },
    "run_id": {
      "title": "Run Id",
      "type": "string"
    },
    "schema_version": {
      "default": "1.0",
      "title": "Schema Version",
      "type": "string"
    }
  },
  "required": [
    "run_id",
    "producer_stage",
    "consumer_stage",
    "producer_agents",
    "consumer_agents",
    "assessments",
    "revision_requests",
    "reward"
  ],
  "title": "HandoffAssessment",
  "type": "object"
}
