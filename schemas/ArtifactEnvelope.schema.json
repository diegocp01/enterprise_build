{
  "$defs": {
    "GateDecision": {
      "enum": [
        "PASS",
        "REPAIR",
        "BLOCKED",
        "INFRA_ERROR"
      ],
      "title": "GateDecision",
      "type": "string"
    },
    "Stage": {
      "enum": [
        "INTAKE",
        "SENSE",
        "MODEL",
        "COMPOSE",
        "DECIDE",
        "SIMULATE",
        "EXECUTE",
        "OBSERVE",
        "DEMO",
        "BUNDLE"
      ],
      "title": "Stage",
      "type": "string"
    }
  },
  "additionalProperties": false,
  "properties": {
    "artifact_id": {
      "title": "Artifact Id",
      "type": "string"
    },
    "artifact_type": {
      "title": "Artifact Type",
      "type": "string"
    },
    "content_digest": {
      "title": "Content Digest",
      "type": "string"
    },
    "content_files": {
      "items": {
        "type": "string"
      },
      "title": "Content Files",
      "type": "array"
    },
    "contract_item_ids": {
      "items": {
        "type": "string"
      },
      "title": "Contract Item Ids",
      "type": "array"
    },
    "created_at": {
      "format": "date-time",
      "title": "Created At",
      "type": "string"
    },
    "gate_status": {
      "$ref": "#/$defs/GateDecision"
    },
    "input_digests": {
      "additionalProperties": {
        "type": "string"
      },
      "title": "Input Digests",
      "type": "object"
    },
    "lead": {
      "title": "Lead",
      "type": "string"
    },
    "peer": {
      "title": "Peer",
      "type": "string"
    },
    "producer_pair": {
      "title": "Producer Pair",
      "type": "string"
    },
    "run_id": {
      "title": "Run Id",
      "type": "string"
    },
    "schema_version": {
      "default": "1.1",
      "title": "Schema Version",
      "type": "string"
    },
    "stage": {
      "$ref": "#/$defs/Stage"
    },
    "version": {
      "minimum": 1,
      "title": "Version",
      "type": "integer"
    }
  },
  "required": [
    "artifact_id",
    "artifact_type",
    "version",
    "run_id",
    "stage",
    "producer_pair",
    "lead",
    "peer",
    "content_files",
    "content_digest",
    "gate_status"
  ],
  "title": "ArtifactEnvelope",
  "type": "object"
}
